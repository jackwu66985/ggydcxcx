page {
  background-color: #f9f7f2;
  color: #1a1a1a;
}

.container {
  height: 100vh;
  background-color: #f9f7f2;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
    sans-serif;
}

.hero {
  padding: 120rpx 40rpx;
  background-color: #1a1a1a;
  color: #f9f7f2;
}

.name {
  font-size: 80rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  opacity: 0.8;
  margin-bottom: 60rpx;
}

.intro {
  font-size: 36rpx;
  line-height: 1.6;
  max-width: 80%;
}

.section {
  padding: 80rpx 40rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #888;
  margin-bottom: 40rpx;
  text-transform: uppercase;
}

.project-card {
  background: #fff;
  margin-bottom: 40rpx;
  border: 1rpx solid #eee;
  padding: 40rpx;
}

.project-tag {
  font-size: 20rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.project-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.project-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.skill-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.skill-item {
  background: #eee;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 4rpx;
  margin: 10rpx;
}

.footer {
  padding: 100rpx 40rpx;
  text-align: center;
  border-top: 1rpx solid #eee;
}

.contact-btn {
  background: #1a1a1a;
  color: #fff;
  display: inline-block;
  padding: 30rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  line-height: 1;
  border-radius: 0;
}

.contact-btn::after {
  border: none;
}

.safe-bottom {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.copyright {
  font-size: 22rpx;
  color: #aaa;
}
